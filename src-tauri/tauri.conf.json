{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "串口调试助手",
  "version": "0.1.0",
  "identifier": "com.serial-debugger.app",
  "build": {
    "frontendDist": "../target/dx/serial-debugger-ui/release/web/public",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "dx serve --port 8080 --interactive false",
    "beforeBuildCommand": "dx build --release --debug-symbols false --no-wasm-opt"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "串口调试助手",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
